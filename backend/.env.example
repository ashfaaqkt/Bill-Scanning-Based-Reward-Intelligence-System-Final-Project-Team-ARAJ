# Copy this file to .env and fill in your own values
# Never commit the real .env file

# Google Gemini AI — get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK — get from Firebase Console → Project Settings → Service Accounts
# Place the JSON file as backend/serviceAccountKey.json
FIREBASE_PROJECT_ID=your_firebase_project_id

# JWT — generate a strong random string (min 32 chars)
JWT_SECRET=replace_this_with_a_strong_random_secret

# Server
PORT=3000

# ML Service URL (Python Flask)
ML_SERVICE_URL=http://localhost:5001
